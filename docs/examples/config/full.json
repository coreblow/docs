{
    "// CoreBlow Gateway — Multi-Channel + OpenAI": "",
    "// Full setup: Telegram + Discord + WebChat with GPT-4o": "",
    "port": 3120,
    "host": "0.0.0.0",
    "token": "cb_YOUR_GATEWAY_AUTH_TOKEN",
    "agent": {
        "provider": "openai",
        "model": "gpt-4o",
        "maxTokens": 4096,
        "temperature": 0.7,
        "workspace": "."
    },
    "providers": {
        "openai": {
            "apiKey": "YOUR_OPENAI_API_KEY"
        },
        "ollama": {
            "baseUrl": "http://127.0.0.1:11434"
        }
    },
    "channels": {
        "telegram": {
            "token": "YOUR_TELEGRAM_BOT_TOKEN"
        },
        "discord": {
            "token": "YOUR_DISCORD_BOT_TOKEN"
        },
        "webchat": {
            "enabled": true
        }
    }
}
